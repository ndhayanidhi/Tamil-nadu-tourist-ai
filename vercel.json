{
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/auth/:path*",
      "destination": "/api/index.ts"
    },
    {
      "source": "/((?!api|auth|.*\\..*).*)",
      "destination": "/index.html"
    }
  ]
}
